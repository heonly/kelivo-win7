From: kelivo-win7 <dev@kelivo.local> Date: 2026-06-29 Subject: [PATCH 6/9] engine: dynamic-load SetThreadDescription/GetThreadDescription  SetThreadDescription and GetThreadDescription are Win10 1607+ APIs. Flutter Engine uses them for debugging thread names.  On Win7, these APIs don't exist. Replace with the legacy RaiseException-based thread naming convention (which VS debuggers still recognize), or quietly skip.  --- a/flutter/shell/platform/windows/thread_helper.cc +++ b/flutter/shell/platform/windows/thread_helper.cc @@ -XX,XX +XX,XX @@  void SetThreadName(const char* name) { -  // Win10+ approach -  HRESULT hr = SetThreadDescription(GetCurrentThread(), -                                    Utf8ToWide(name).c_str()); +  // Win7-compatible approach: dynamic load or legacy +  using SetThreadDescriptionFunc = HRESULT(WINAPI*)(HANDLE, PCWSTR); +  auto SetThreadDescription = +      reinterpret_cast<SetThreadDescriptionFunc>( +          GetProcAddress(GetModuleHandleW(L"kernel32.dll"), +                         "SetThreadDescription")); +  if (SetThreadDescription) { +    SetThreadDescription(GetCurrentThread(), Utf8ToWide(name).c_str()); +  } else { +    // Win7: legacy RaiseException naming +    // (VS debugger still picks this up) +    const DWORD MS_VC_EXCEPTION = 0x406D1388; +    struct THREADNAME_INFO { +      DWORD dwType;     // Must be 0x1000. +      LPCSTR szName;    // Pointer to name (in user addr space). +      DWORD dwThreadID; // Thread ID (-1 = caller thread). +      DWORD dwFlags;    // Reserved for future use, must be zero. +    }; +    THREADNAME_INFO info = {0x1000, name, -1, 0}; +    RaiseException(MS_VC_EXCEPTION, 0, sizeof(info) / sizeof(ULONG_PTR), +                   reinterpret_cast<ULONG_PTR*>(&info)); +  }  === How to generate this patch === Run in engine/src/flutter:   grep -rn "SetThreadDescription" shell/platform/windows/   # Edit the relevant file and:   git diff > 0006-embedder-thread-naming-compat.patch